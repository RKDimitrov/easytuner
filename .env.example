# EasyTuner Docker Compose – required when running from repo root
# Copy to .env in this directory:  cp .env.example .env
#
# When you run:  docker compose up -d   (or down)  from D:\easytuner
# Compose reads this directory's .env. Set these or use the defaults in docker-compose*.yml.

# PostgreSQL (used by postgres service)
POSTGRES_DB=easytuner
POSTGRES_USER=easytuner
POSTGRES_PASSWORD=your_postgres_password_here

# Redis (used by redis service)
REDIS_PASSWORD=your_redis_password_here

# Server (used by server service)
JWT_SECRET_KEY=your_jwt_secret_at_least_32_characters_long

# Optional: Map Assistant (in server/.env for the app; not required for Compose)
# OPENAI_API_KEY=sk-...
