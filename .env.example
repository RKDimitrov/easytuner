# EasyTuner Environment Variables
# ================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# PostgreSQL
POSTGRES_DB=easytuner
POSTGRES_USER=easytuner
POSTGRES_PASSWORD=change_me_strong_password

# Redis
# Generate a strong password, e.g.: openssl rand -hex 32
REDIS_PASSWORD=change_me_strong_redis_password

# JWT
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=change_me_very_long_random_secret_key

# MinIO (only needed for docker-compose.full.yml)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_minio_password

# CORS (optional override)
# CORS_ORIGINS=["http://localhost:3000","https://easytuner.me"]
