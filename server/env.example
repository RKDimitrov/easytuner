# EasyTuner Server Configuration
#
# 1. Copy this file to .env:
#    cp env.example .env
#
# 2. Edit .env with your database URL, JWT secret, etc.
#
# 3. To enable the Map Assistant (AI chat on the Analysis page):
#    Set GEMINI_API_KEY to your Google AI Studio key (free at https://aistudio.google.com/app/apikey).
#    If unset, the assistant is disabled and the chat shows a "not configured" message.
#
# 4. Run the server (from project root with Docker, or from server/ with Poetry):
#    docker-compose up -d
#    or: poetry run uvicorn app.main:app --reload

# Application
APP_NAME=EasyTuner Server
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Database
DATABASE_URL=postgresql+asyncpg://easytuner:password@localhost:5432/easytuner
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=easytuner-uploads
MINIO_BUCKET_EXPORTS=easytuner-exports
MINIO_SECURE=false

# Authentication (CHANGE THESE IN PRODUCTION!)
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS_LONG
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Security
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://easytuner.me","https://www.easytuner.me"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# File Upload
MAX_UPLOAD_SIZE_MB=16
ALLOWED_FILE_EXTENSIONS=[".bin", ".hex"]

# Rate Limiting
RATE_LIMIT_UPLOADS_PER_HOUR=100
RATE_LIMIT_SCANS_PER_HOUR=50
RATE_LIMIT_EXPORTS_PER_HOUR=20
RATE_LIMIT_READS_PER_HOUR=1000

# Detection Pipeline
SCAN_TIMEOUT_SECONDS=300
MAX_CANDIDATES_PER_SCAN=500

# Map Assistant (Google Gemini free tier)
# Get a free API key at https://aistudio.google.com/app/apikey
# Leave GEMINI_API_KEY unset to disable the assistant.
# IMPORTANT: Not all projects have access to the same models.
# In Google AI Studio, open a new prompt and copy the exact model ID
# from the model dropdown (e.g. gemini-2.0-flash) into GEMINI_MODEL.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

