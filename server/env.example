# EasyTuner Server Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME=EasyTuner Server
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Database
DATABASE_URL=postgresql+asyncpg://easytuner:password@localhost:5432/easytuner
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=easytuner-uploads
MINIO_BUCKET_EXPORTS=easytuner-exports
MINIO_SECURE=false

# Authentication (CHANGE THESE IN PRODUCTION!)
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS_LONG
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Security
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://easytuner.me","https://www.easytuner.me"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# File Upload
MAX_UPLOAD_SIZE_MB=16
ALLOWED_FILE_EXTENSIONS=[".bin", ".hex"]

# Rate Limiting
RATE_LIMIT_UPLOADS_PER_HOUR=100
RATE_LIMIT_SCANS_PER_HOUR=50
RATE_LIMIT_EXPORTS_PER_HOUR=20
RATE_LIMIT_READS_PER_HOUR=1000

# Detection Pipeline
SCAN_TIMEOUT_SECONDS=300
MAX_CANDIDATES_PER_SCAN=500

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

