# EasyTuner Root .gitignore
# ==========================

# Operating System Files
# -----------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE and Editor Files
# --------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Environment Variables
# ---------------------
.env
.env.local
.env.*.local
*.env

# Logs
# ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporary Files
# ---------------
tmp/
temp/
*.tmp
*.temp

# Build Outputs (general)
# -----------------------
dist/
build/
out/

# Testing
# -------
coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# Python
# ------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Docker
# ------
*.pid
*.seed
*.pid.lock

# Backup Files
# ------------
*.bak
*.backup
*.old
*.orig

# Sensitive Data
# --------------
secrets/
*.key
*.pem
*.p12
*.pfx

# Database
# --------
*.db
*.sqlite
*.sqlite3

# Documentation Build
# -------------------
docs/_build/
docs/.doctrees/
docs/

# Project Specific
# ----------------
uploads/
exports/
data/
*.bin
*.hex

# Not needed for MVP
monitoring/
scripts/

